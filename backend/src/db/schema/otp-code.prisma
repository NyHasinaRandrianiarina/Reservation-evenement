model OtpCode {
  id         String    @id @default(uuid())
  code       String    @db.VarChar(255)
  user_id    String
  type       OtpType
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([code, user_id])
}
