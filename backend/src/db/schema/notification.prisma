model Notification {
  id         String   @id @default(uuid())
  user_id    String?
  type       String
  title      String
  message    String   @db.Text
  metadata   Json?
  read_at    DateTime?
  created_at DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, read_at])
  @@index([created_at])
}
